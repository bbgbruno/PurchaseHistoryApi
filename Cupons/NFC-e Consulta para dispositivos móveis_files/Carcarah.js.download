//objeto usado para verificar a versăo do navegador
var BrowserDetect = {
    init: function () {
        this.browser = this.searchString(this.dataBrowser) || "Other";
        this.version = this.searchVersion(navigator.userAgent) || this.searchVersion(navigator.appVersion) || "Unknown";
    },
    searchString: function (data) {
        for (var i = 0; i < data.length; i++) {
            var dataString = data[i].string;
            this.versionSearchString = data[i].subString;

            if (dataString.indexOf(data[i].subString) !== -1) {
                return data[i].identity;
            }
        }
    },
    searchVersion: function (dataString) {
        var index = dataString.indexOf(this.versionSearchString);
        if (index === -1) {
            return;
        }

        var rv = dataString.indexOf("rv:");
        if (this.versionSearchString === "Trident" && rv !== -1) {
            return parseFloat(dataString.substring(rv + 3));
        } else {
            return parseFloat(dataString.substring(index + this.versionSearchString.length + 1));
        }
    },

    dataBrowser: [
        { string: navigator.userAgent, subString: "Chrome", identity: "Chrome" },
        { string: navigator.userAgent, subString: "MSIE", identity: "Explorer" },
        { string: navigator.userAgent, subString: "Trident", identity: "Explorer" },
        { string: navigator.userAgent, subString: "Firefox", identity: "Firefox" },
        { string: navigator.userAgent, subString: "Safari", identity: "Safari" },
        { string: navigator.userAgent, subString: "Opera", identity: "Opera" }
    ]

};

BrowserDetect.init();


function bloquearTela(modal) {

    $.blockUI({ message: '', css: { backgroundColor: 'transparent' } });

    $('.blockUI.blockOverlay').on('click', function (e) {
        e.stopPropagation();
        modal.focus();
    });

    $(modal).on('load', function (e) {

        e.stopPropagation();
        modal.focus();

    }).on('unload', function () {

        setTimeout(function () {

            if (modal.closed) {
                $.unblockUI({ fadeOut: 50 });
            }
        }, 800);
    });
}

// Funçăo utilizada para restaurar a p?gina ao in?cio da tela, quando o ajax está sendo usado
function RestauraTela() {
    window.scrollTo(0, 0);
    return true;
}

function DirecionaFoco(pIdControle) {
    pIdControle.Focus();
}

// Funçăo do Framework
function MudaTabEnter() {
    if (event.keyCode == 13)
        event.keyCode = 9;
}

//A tecla ENTER fica com a mesma funcionalidade que a tecla TAB
function TABEnter(oEvent) {
    var oEvent = (oEvent) ? oEvent : event;
    var oTarget = (oEvent.target) ? oEvent.target : oEvent.srcElement;
    if (oEvent.keyCode == 13)
        oEvent.keyCode = 9;
    if (oTarget.type == "text" && oEvent.keyCode == 13)
        oEvent.keyCode = 9;
    if (oTarget.type == "radio" && oEvent.keyCode == 13)
        oEvent.keyCode = 9;
}

//Para ser usada em lugar do confirm do javascript
function Confirma(pMensagem) {
    pMensagem = "<p align=\"center\">" + pMensagem + "</p>";
    Confirma(pMensagem, null, null, null, null, false);
}


function ConfirmaCancelando(pMensagem, pPagina, pIdCampoRetorno, pLargura, pAltura, pExecutaPost, pPermiteCallbackCancelar) {

    if (pPagina == null) {
        pPagina = caminhoRaiz + "Mensagem.aspx";
    }

    if (pLargura == null) {
        pLargura = 400;
    }

    if (pAltura == null) {

        pAltura = 200;
    }

    var argumentos;

    if (navigator.appName == "Microsoft Internet Explorer") {

        argumentos = new Array(3);
        argumentos[0] = self;
        argumentos[1] = pMensagem;
        argumentos[3] = pPermiteCallbackCancelar;

        window.showModalDialog(pPagina, argumentos, "dialogWidth:'" + pLargura + "px';dialogHeight:'" + pAltura + "px'; toolbar='no';directories='no';status='no';menubar=no;scrollbars='no';resizable='no'");

        if (pExecutaPost) {

            $(self.document).ready(function () {

                var $campo = $('#' + pIdCampoRetorno + '');

                $campo.val(argumentos[2]);

                self.document.all.aspnetForm.submit();

            });
        }

        return argumentos[2];
    }
    else {

        var left = (screen.width / 2) - (pLargura / 2);
        var top = (screen.height / 2) - (pAltura / 2);

        _args_mensagem = pMensagem;
        _args_submeter_pagina_confirma_retorno = pExecutaPost;
        _args_campo_retorno = pIdCampoRetorno;
        _args_cancelar = pPermiteCallbackCancelar;

        var modal = window.open(pPagina, '' + pIdCampoRetorno + '', 'toolbar=no ,modal=yes, status=no, titlebar=no, menubar=no,width=' + pLargura + ', height=' + pAltura + ', top=' + top + ',left=' + left);
        bloquearTela(modal);
    }

}

